# push this comment to create .env file

DATABASE_URL=postgresql://admin:admin@localhost:5432/mydatabase
DATABASE_POOL_MAX=5
DATABASE_POOL_IDLE_TIMEOUT_MS=300000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
JWT_ACCESS_TOKEN_SECRET=your_access_token_secret_key
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

