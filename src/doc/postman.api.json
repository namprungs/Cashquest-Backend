    {
      "name": "Quiz",
      "item": [
        {
          "name": "Create Quiz Snapshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": \"{{moduleId}}\",\n  \"timeLimitSec\": 1200,\n  \"passAllRequired\": false,\n  \"questions\": [\n    {\n      \"orderNo\": 1,\n      \"questionText\": \"2 + 2 = ?\",\n      \"questionType\": \"SINGLE_CHOICE\",\n      \"points\": 1,\n      \"gradingType\": \"AUTO\",\n      \"choices\": [\n        { \"orderNo\": 1, \"choiceText\": \"3\", \"isCorrect\": false },\n        { \"orderNo\": 2, \"choiceText\": \"4\", \"isCorrect\": true }\n      ]\n    },\n    {\n      \"orderNo\": 2,\n      \"questionText\": \"Capital of Thailand\",\n      \"questionType\": \"SHORT_TEXT\",\n      \"points\": 1,\n      \"gradingType\": \"AUTO\",\n      \"answerKey\": {\n        \"acceptedAnswers\": [\"Bangkok\", \"Krung Thep\"],\n        \"ignoreCase\": true,\n        \"trim\": true\n      },\n      \"choices\": []\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Update Quiz Snapshot",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": \"{{moduleId}}\",\n  \"timeLimitSec\": 1500,\n  \"passAllRequired\": false,\n  \"questions\": [\n    {\n      \"id\": \"<existing-question-id>\",\n      \"orderNo\": 1,\n      \"questionText\": \"2 + 2 = ? (updated)\",\n      \"questionType\": \"SINGLE_CHOICE\",\n      \"points\": 1,\n      \"gradingType\": \"AUTO\",\n      \"choices\": [\n        { \"id\": \"<existing-choice-id-1>\", \"orderNo\": 1, \"choiceText\": \"3\", \"isCorrect\": false },\n        { \"id\": \"<existing-choice-id-2>\", \"orderNo\": 2, \"choiceText\": \"4\", \"isCorrect\": true }\n      ]\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "List Quizzes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes?termId={{termId}}&moduleId={{moduleId}}&search=math",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"],
              "query": [
                { "key": "termId", "value": "{{termId}}" },
                { "key": "moduleId", "value": "{{moduleId}}" },
                { "key": "search", "value": "math" }
              ]
            }
          }
        },
