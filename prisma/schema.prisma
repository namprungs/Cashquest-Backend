generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// 1. IDENTITY & ACCESS MANAGEMENT (IAM)
// ---------------------------------------------------------

model User {
  id       String  @id @default(uuid()) @db.Uuid
  email    String  @unique
  username String  @unique
  password String
  roleId   String? @db.Uuid
  role     Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isActive Boolean @default(true)

  // Relations
  schoolId          String?            @db.Uuid
  school            School?            @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  tokens            RefreshToken[]
  classroomStudents ClassroomStudent[]
  classrooms        Classroom[] // For Teachers
  studentProfiles   StudentProfile[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  quizAttemptAnswers QuizAttemptAnswer[]
  quests             Quest[]
  questSubmissions   QuestSubmission[]

  @@map("users") // Mapping to lowercase table name in DB
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String @id @default(uuid()) @db.Uuid
  tokenHash String @unique
  userId    String @db.Uuid
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token Rotation Logic
  replacedById String?        @db.Uuid
  replacedBy   RefreshToken?  @relation("TokenReplacements", fields: [replacedById], references: [id])
  previous     RefreshToken[] @relation("TokenReplacements")

  expiresAt DateTime
  revokedAt DateTime?

  // Metadata
  createdByIp String?
  userAgent   String?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  deviceId    String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------
// 2. EDUCATIONAL STRUCTURE
// ---------------------------------------------------------

model School {
  id   String @id @default(uuid()) @db.Uuid
  name String
  plan String @default("FREE")

  // Relations
  users User[]
  terms Term[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schools")
}

model Term {
  id       String @id @default(uuid()) @db.Uuid
  schoolId String @db.Uuid
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name       String // e.g., "Term 1/2025"
  startDate  DateTime
  endDate    DateTime
  totalWeeks Int
  status     TermStatus @default(DRAFT)

  // Relations
  termWeeks       TermWeek[]
  termStageRules  TermStageRule[]
  classrooms      Classroom[]
  studentProfiles StudentProfile[]
  banks           Bank[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  learningModules       LearningModule[]
  quests                Quest[]
  productSimulations    ProductSimulation[]
  termSimulation        TermSimulation?
  productPrices         ProductPrice[]
  productLivePriceTicks ProductLivePriceTick[]
  orders                Order[]
  holdings              Holding[]
  dividendPayouts       DividendPayout[]
  bondPositions         BondPosition[]
  termEvents            TermEvent[]
  marketRegimes         MarketRegime[]
  badges                Badge[]
  investmentWallets     InvestmentWallet[]

  @@map("terms")
}

enum TermStatus {
  DRAFT
  ONGOING
  COMPLETED
}

model TermWeek {
  id     String @id @default(uuid()) @db.Uuid
  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  weekNo    Int // 1, 2, 3...
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("term_weeks")
}

model Classroom {
  id   String @id @default(uuid()) @db.Uuid
  name String

  // Links
  teacherId String @db.Uuid
  teacher   User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  termId    String @db.Uuid
  term      Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  // Relations
  students ClassroomStudent[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  questClassrooms QuestClassroom[]

  @@map("classrooms")
}

model ClassroomStudent {
  id          String @id @default(uuid()) @db.Uuid
  classroomId String @db.Uuid
  studentId   String @db.Uuid

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([classroomId, studentId])
  @@map("classroom_students")
}

// ---------------------------------------------------------
// 3. SIMULATION LOGIC & RULES
// ---------------------------------------------------------

model LifeStage {
  id      String @id @default(uuid()) @db.Uuid
  name    String // e.g., "HIGH_SCHOOL"
  orderNo Int // For sorting logic

  unlockInvestment    Boolean @default(false)
  enableRandomExpense Boolean @default(false)

  // Relations
  termStageRules TermStageRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("life_stages")
}

model TermStageRule {
  id          String @id @default(uuid()) @db.Uuid
  termId      String @db.Uuid
  lifeStageId String @db.Uuid

  startWeek Int @default(1)
  endWeek   Int

  term      Term      @relation(fields: [termId], references: [id], onDelete: Cascade)
  lifeStage LifeStage @relation(fields: [lifeStageId], references: [id], onDelete: Cascade)

  @@map("term_stage_rules")
}

// ---------------------------------------------------------
// 4. STUDENT PROGRESSION (GAMEPLAY)
// ---------------------------------------------------------

model StudentProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  // Relations
  retirementGoals RetirementGoal[]
  mainWallet      Wallet?           @relation("MainWallet") // 1-to-1 main wallet
  investmentWallet InvestmentWallet? @relation("InvestmentWallet") // 1-to-1 investment wallet
  savingsAccounts SavingsAccount[]
  fixedDeposits   FixedDeposit[]
  studentBadges   StudentBadge[]

  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  quizAttempts            QuizAttempt[]
  questSubmissions        QuestSubmission[]
  questLearningProgresses QuestLearningProgress[]
  orders                  Order[]
  holdings                Holding[]
  dividendPayouts         DividendPayout[]

  @@unique([userId, termId])
  @@map("student_profiles")
}

model RetirementGoal {
  id               String         @id @default(uuid()) @db.Uuid
  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  retirementAge  Int     @default(60) // เช่น 65
  monthlyExpense Decimal @db.Decimal(12, 2)
  lifeExpectancy Int // optional เช่น 85

  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @db.Decimal(12, 2)
  targetDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("retirement_goals")
}

model Badge {
  id     String @id @default(uuid()) @db.Uuid
  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  code        String
  name        String
  description String?
  ruleJson    Json    @db.JsonB

  studentBadges StudentBadge[]

  @@unique([termId, code])
  @@index([termId])
  @@map("badges")
}

model StudentBadge {
  studentProfileId String @db.Uuid
  badgeId          String @db.Uuid

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  badge          Badge          @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now()) @db.Timestamptz(6)

  @@id([studentProfileId, badgeId])
  @@index([badgeId])
  @@map("student_badges")
}

// ---------------------------------------------------------
// 5. FINANCIAL SYSTEM (WALLET & BANKING)
// ---------------------------------------------------------

model Wallet {
  id               String         @id @default(uuid()) @db.Uuid
  // ✅ เชื่อมกับ StudentProfile แทน User+Term
  studentProfileId String         @unique @db.Uuid
  studentProfile   StudentProfile @relation("MainWallet", fields: [studentProfileId], references: [id], onDelete: Cascade)

  balance Decimal @default(0) @db.Decimal(12, 2) // รองรับพันล้าน และทศนิยม 2 ตำแหน่ง

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model InvestmentWallet {
  id               String         @id @default(uuid()) @db.Uuid
  studentProfileId String         @unique @db.Uuid
  studentProfile   StudentProfile @relation("InvestmentWallet", fields: [studentProfileId], references: [id], onDelete: Cascade)

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  balance Decimal @default(0) @db.Decimal(12, 2)

  transactions InvestmentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([termId])
  @@map("investment_wallets")
}

model WalletTransaction {
  id       String @id @default(uuid()) @db.Uuid
  walletId String @db.Uuid
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type          TransactionType // ENUM: INCOME, EXPENSE, TRANSFER
  amount        Decimal         @db.Decimal(12, 2)
  balanceBefore Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)

  // ✅ ใช้ JSON เก็บ Reference แทนการแยก column table/id (Prisma จัดการง่ายกว่า)
  // ตัวอย่าง: { "source": "QUEST", "refId": "uuid-123" }
  metadata    Json?
  description String?

  createdAt DateTime @default(now())

  @@map("wallet_transactions")
}

enum TransactionType {
  QUEST_REWARD
  BANK_DEPOSIT
  BANK_WITHDRAW
  FINE_PAYMENT
  TRANSFER_IN
  TRANSFER_OUT
}

model InvestmentTransaction {
  id                 String           @id @default(uuid()) @db.Uuid
  investmentWalletId String           @db.Uuid
  investmentWallet   InvestmentWallet @relation(fields: [investmentWalletId], references: [id], onDelete: Cascade)

  type          InvestmentTransactionType
  amount        Decimal                   @db.Decimal(12, 2)
  balanceBefore Decimal                   @db.Decimal(12, 2)
  balanceAfter  Decimal                   @db.Decimal(12, 2)

  metadata    Json?
  description String?

  createdAt DateTime @default(now())

  @@index([investmentWalletId, createdAt])
  @@map("investment_transactions")
}

enum InvestmentTransactionType {
  STOCK_BUY
  STOCK_SELL
  TRANSFER_IN
  TRANSFER_OUT
  DIVIDEND
  COUPON
}

// --- BANKING SYSTEM ---

model Bank {
  id     String @id @default(uuid()) @db.Uuid
  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  name String

  // Rules
  interestRate         Decimal @db.Decimal(5, 4) // เช่น 0.0150 (1.5%)
  withdrawLimitPerTerm Int? // null = unlimited
  feePerTransaction    Decimal @default(0) @db.Decimal(10, 2)

  savingsAccounts SavingsAccount[]
  fixedDeposits   FixedDeposit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banks")
}

model SavingsAccount {
  id               String         @id @default(uuid()) @db.Uuid
  // ✅ เชื่อมกับ StudentProfile
  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  bankId String @db.Uuid
  bank   Bank   @relation(fields: [bankId], references: [id], onDelete: Cascade)

  balance       Decimal @default(0) @db.Decimal(12, 2)
  withdrawCount Int     @default(0)
  status        String  @default("ACTIVE") // ACTIVE, CLOSED

  interestLogs SavingsInterestLog[]
  // ✅ เพิ่ม Transaction ของธนาคารด้วย
  transactions SavingsTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentProfileId, bankId]) // 1 คนมีได้ 1 บัญชีต่อ 1 ธนาคาร
  @@map("savings_accounts")
}

model SavingsTransaction {
  id               String         @id @default(uuid()) @db.Uuid
  savingsAccountId String         @db.Uuid
  savingsAccount   SavingsAccount @relation(fields: [savingsAccountId], references: [id], onDelete: Cascade)

  type         String // DEPOSIT, WITHDRAW, INTEREST, FEE
  amount       Decimal @db.Decimal(12, 2)
  balanceAfter Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("savings_transactions")
}

model SavingsInterestLog {
  id               String         @id @default(uuid()) @db.Uuid
  savingsAccountId String         @db.Uuid
  savingsAccount   SavingsAccount @relation(fields: [savingsAccountId], references: [id], onDelete: Cascade)

  weekNo         Int
  rateUsed       Decimal @db.Decimal(5, 4)
  interestAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("savings_interest_logs")
}

model FixedDeposit {
  id               String         @id @default(uuid()) @db.Uuid
  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  bankId String @db.Uuid
  bank   Bank   @relation(fields: [bankId], references: [id], onDelete: Cascade)

  principal      Decimal @db.Decimal(12, 2) // เงินต้น
  interestRate   Decimal @db.Decimal(5, 4) // ดอกเบี้ยตามตกลง
  startWeekNo    Int
  maturityWeekNo Int // สัปดาห์ที่ครบกำหนด

  status String @default("ACTIVE") // ACTIVE, MATURED, WITHDRAWN_EARLY

  transactions FixedDepositTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fixed_deposits")
}

model FixedDepositTransaction {
  id             String       @id @default(uuid()) @db.Uuid
  fixedDepositId String       @db.Uuid
  fixedDeposit   FixedDeposit @relation(fields: [fixedDepositId], references: [id], onDelete: Cascade)

  type           String
  principal      Decimal @db.Decimal(12, 2)
  interestAmount Decimal @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal @db.Decimal(12, 2)
  description    String?

  createdAt DateTime @default(now())

  @@map("fixed_deposit_transactions")
}

// ---------------------------------------------------------
// 6. LEARNING + QUIZ + QUEST (Integrated from dbdiagram)
// Student relations => StudentProfile
// Teacher relations => User
// ---------------------------------------------------------

// -------------------------
// Learning Modules
// -------------------------
model LearningModule {
  id     String @id @default(uuid()) @db.Uuid
  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  title       String
  description String?
  contentUrl  String? @map("content_url")
  orderNo     Int     @map("order_no")
  isActive    Boolean @default(true) @map("is_active")

  quizzes Quiz[]
  quests  Quest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([termId, orderNo])
  @@map("learning_modules")
}

// -------------------------
// Quiz
// -------------------------
model Quiz {
  id       String          @id @default(uuid()) @db.Uuid
  moduleId String?         @db.Uuid
  module   LearningModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  timeLimitSec    Int?    @map("time_limit_sec")
  passAllRequired Boolean @default(false) @map("pass_all_required")

  questions QuizQuestion[]
  attempts  QuizAttempt[]
  quests    Quest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([moduleId])
  @@map("quizzes")
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUEFALSE
  SHORT_TEXT
  LONG_TEXT
  NUMERIC
  FILE_UPLOAD
}

enum QuizGradingType {
  AUTO
  MANUAL
}

model QuizQuestion {
  id     String @id @default(uuid()) @db.Uuid
  quizId String @db.Uuid
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  questionText String           @map("question_text")
  questionType QuizQuestionType @map("question_type")
  orderNo      Int              @map("order_no")
  points       Int              @default(1)

  gradingType QuizGradingType @default(AUTO) @map("grading_type")
  answerKey   Json?           @map("answer_key")
  config      Json?

  choices        QuizChoice[]
  attemptAnswers QuizAttemptAnswer[]
  answerChoices  QuizAttemptAnswerChoice[]
  attachments    QuizAttemptAnswerAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quizId, orderNo])
  @@map("quiz_questions")
}

model QuizChoice {
  id         String       @id @default(uuid()) @db.Uuid
  questionId String       @db.Uuid
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  choiceText String  @map("choice_text")
  isCorrect  Boolean @default(false) @map("is_correct")
  orderNo    Int     @map("order_no")

  pickedBy QuizAttemptAnswerChoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([questionId, orderNo])
  @@map("quiz_choices")
}

// Attempt header (student => StudentProfile)
model QuizAttempt {
  id               String         @id @default(uuid()) @db.Uuid
  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  quizId String @db.Uuid
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  score       Int       @default(0)
  isPassed    Boolean   @default(false) @map("is_passed")
  attemptNo   Int       @map("attempt_no")
  submittedAt DateTime? @map("submitted_at")

  answers             QuizAttemptAnswer[]
  selectedChoices     QuizAttemptAnswerChoice[]
  attachments         QuizAttemptAnswerAttachment[]
  progressAsFirstPass QuestLearningProgress[]       @relation("FirstPassAttempt")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([studentProfileId, quizId, attemptNo])
  @@index([quizId, submittedAt])
  @@map("quiz_attempts")
}

// Per-question answer (text/numeric/file + grading fields)
model QuizAttemptAnswer {
  attemptId  String @db.Uuid
  questionId String @db.Uuid

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  answerText    String?  @map("answer_text")
  answerNumber  Decimal? @map("answer_number") @db.Decimal(18, 6)
  attachmentUrl String?  @map("attachment_url")

  isCorrect     Boolean? @map("is_correct")
  awardedPoints Int?     @map("awarded_points")

  // reviewer => teacher(user)
  reviewerId String? @map("reviewer_id") @db.Uuid
  reviewer   User?   @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  reviewedAt DateTime? @map("reviewed_at")
  feedback   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([attemptId, questionId])
  @@index([questionId])
  @@index([reviewerId])
  @@map("quiz_attempt_answers")
}

// Multi-select / selected choices
model QuizAttemptAnswerChoice {
  attemptId  String @db.Uuid
  questionId String @db.Uuid
  choiceId   String @db.Uuid

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choice   QuizChoice   @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([attemptId, questionId, choiceId])
  @@index([choiceId])
  @@map("quiz_attempt_answer_choices")
}

// Optional: multiple attachments per question
model QuizAttemptAnswerAttachment {
  id         String @id @default(uuid()) @db.Uuid
  attemptId  String @db.Uuid
  questionId String @db.Uuid

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  fileUrl       String   @map("file_url")
  fileName      String?  @map("file_name")
  mimeType      String?  @map("mime_type")
  fileSizeBytes BigInt?  @map("file_size_bytes")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  @@index([attemptId, questionId])
  @@map("quiz_attempt_answer_attachments")
}

// -------------------------
// Quest
// -------------------------
enum QuestType {
  QUIZ
  ASSIGNMENT
  PROJECT
  INTERACTIVE
  OTHER
}

enum QuestStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestSubmissionType {
  TEXT
  LINK
  FILE
}

model Quest {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  // teacher/creator => User
  createdById String @map("created_by") @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  type             QuestType
  learningModuleId String?         @map("learning_module_id") @db.Uuid
  learningModule   LearningModule? @relation(fields: [learningModuleId], references: [id], onDelete: SetNull)

  quizId String? @map("quiz_id") @db.Uuid
  quiz   Quiz?   @relation(fields: [quizId], references: [id], onDelete: SetNull)

  title          String
  description    String?
  isSystem       Boolean              @default(false) @map("is_system")
  rewardCoins    Int                  @default(0) @map("reward_coins")
  submissionType QuestSubmissionType? @map("submission_type")
  status         QuestStatus          @default(DRAFT)

  startAt    DateTime? @map("start_at")
  deadlineAt DateTime? @map("deadline_at")

  classrooms  QuestClassroom[]
  submissions QuestSubmission[]
  progress    QuestLearningProgress[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([termId, status])
  @@index([quizId])
  @@index([learningModuleId])
  @@map("quests")
}

model QuestClassroom {
  questId     String @db.Uuid
  classroomId String @db.Uuid

  quest     Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@id([questId, classroomId])
  @@map("quest_classrooms")
}

// Submission (student => StudentProfile)
enum QuestSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model QuestSubmission {
  id String @id @default(uuid()) @db.Uuid

  questId String @db.Uuid
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)

  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  status          QuestSubmissionStatus @default(PENDING)
  latestVersionNo Int                   @default(1) @map("latest_version_no")

  reviewedById String? @map("reviewed_by") @db.Uuid
  reviewedBy   User?   @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  rejectReason String? @map("reject_reason")

  versions QuestSubmissionVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([questId, studentProfileId])
  @@index([reviewedById])
  @@map("quest_submissions")
}

model QuestSubmissionVersion {
  id String @id @default(uuid()) @db.Uuid

  submissionId String          @db.Uuid
  submission   QuestSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  versionNo     Int     @map("version_no")
  payloadJson   Json?   @map("payload_json")
  attachmentUrl String? @map("attachment_url")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([submissionId, versionNo])
  @@map("quest_submission_versions")
}

// Progress for learning+quiz quest (student => StudentProfile)
model QuestLearningProgress {
  id String @id @default(uuid()) @db.Uuid

  questId String @db.Uuid
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)

  studentProfileId String         @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  videoStartedAt   DateTime? @map("video_started_at")
  videoCompletedAt DateTime? @map("video_completed_at")

  isQuizUnlocked Boolean @default(false) @map("is_quiz_unlocked")

  firstPassAttemptId String?      @map("first_pass_attempt_id") @db.Uuid
  firstPassAttempt   QuizAttempt? @relation("FirstPassAttempt", fields: [firstPassAttemptId], references: [id], onDelete: SetNull)

  isCompleted Boolean @default(false) @map("is_completed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([questId, studentProfileId])
  @@index([firstPassAttemptId])
  @@map("quest_learning_progress")
}

// ---------------------------------------------------------
// 7. INVESTMENT & ECONOMIC EVENT
// Student relations => StudentProfile
// ---------------------------------------------------------

enum ProductType {
  STOCK
  FUND
  BOND
}

enum RiskLevel {
  LOW
  MED
  HIGH
}

enum PriceGenerationType {
  GBM
  GBM_EVENT_ADJUSTED
  LIVE_TICK
  LIVE_FINALIZED
  MANUAL
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  EXECUTED
  CANCELLED
}

enum BondPositionStatus {
  ACTIVE
  MATURED
  CLOSED
}

enum EconomicEventType {
  VOLATILITY_SHOCK
  DRIFT_SHIFT
  MARKET_CRASH
  SECTOR_SPECIFIC
  REGIME_CHANGE
}

enum TermEventStatus {
  SCHEDULED
  ACTIVE
  EXPIRED
}

enum MarketRegimeName {
  BULL
  BEAR
  SIDEWAYS
}

model Product {
  id String @id @default(uuid()) @db.Uuid

  type      ProductType
  symbol    String      @unique
  name      String
  riskLevel RiskLevel   @map("risk_level")
  sector    String?
  metaJson  Json?       @map("meta_json")
  isActive  Boolean     @default(true) @map("is_active")

  simulations     ProductSimulation[]
  prices          ProductPrice[]
  livePriceTicks  ProductLivePriceTick[]
  orders          Order[]
  holdings        Holding[]
  dividendPayouts DividendPayout[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("products")
}

model ProductSimulation {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  initialPrice Decimal @map("initial_price") @db.Decimal(18, 6)
  mu           Decimal @db.Decimal(10, 6)
  sigma        Decimal @db.Decimal(10, 6)
  dt           Decimal @db.Decimal(10, 6)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([termId, productId])
  @@map("product_simulations")
}

model TermSimulation {
  id String @id @default(uuid()) @db.Uuid

  termId String @unique @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  randomSeed    Int    @map("random_seed")
  currentWeek   Int    @default(1) @map("current_week")
  engineVersion String @map("engine_version")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("term_simulations")
}

model ProductPrice {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  weekNo Int @map("week_no")

  open      Decimal @db.Decimal(18, 6)
  high      Decimal @db.Decimal(18, 6)
  low       Decimal @db.Decimal(18, 6)
  close     Decimal @db.Decimal(18, 6)
  returnPct Decimal @map("return_pct") @db.Decimal(10, 6)

  muUsed    Decimal? @map("mu_used") @db.Decimal(10, 6)
  sigmaUsed Decimal? @map("sigma_used") @db.Decimal(10, 6)

  eventId        String?             @map("event_id") @db.Uuid
  event          EconomicEvent?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  generationType PriceGenerationType @map("generation_type")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([termId, productId, weekNo])
  @@index([eventId])
  @@map("product_prices")
}

model ProductLivePriceTick {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  simulatedWeekNo Int      @map("simulated_week_no")
  tickedAt        DateTime @default(now()) @map("ticked_at")

  price     Decimal @db.Decimal(18, 6)
  returnPct Decimal @map("return_pct") @db.Decimal(10, 6)

  muUsed    Decimal? @map("mu_used") @db.Decimal(10, 6)
  sigmaUsed Decimal? @map("sigma_used") @db.Decimal(10, 6)

  eventId        String?             @map("event_id") @db.Uuid
  event          EconomicEvent?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  generationType PriceGenerationType @map("generation_type")

  @@index([termId, productId, simulatedWeekNo, tickedAt])
  @@index([termId, simulatedWeekNo, tickedAt])
  @@index([eventId])
  @@map("product_live_price_ticks")
}

model Order {
  id String @id @default(uuid()) @db.Uuid

  studentProfileId String         @map("student_profile_id") @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  side      OrderSide
  orderType OrderType @map("order_type")

  requestedPrice Decimal? @map("requested_price") @db.Decimal(18, 6)
  executedPrice  Decimal? @map("executed_price") @db.Decimal(18, 6)

  quantity Decimal @db.Decimal(18, 6)
  fee      Decimal @default(0) @db.Decimal(18, 6)

  weekNo Int         @map("week_no")
  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([studentProfileId, termId, weekNo])
  @@index([termId, productId])
  @@map("orders")
}

model Holding {
  id String @id @default(uuid()) @db.Uuid

  studentProfileId String         @map("student_profile_id") @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  units   Decimal @default(0) @db.Decimal(18, 6)
  avgCost Decimal @default(0) @map("avg_cost") @db.Decimal(18, 6)

  bondPositions BondPosition[]

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentProfileId, termId, productId])
  @@map("holdings")
}

model DividendPayout {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  studentProfileId String         @map("student_profile_id") @db.Uuid
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  weekNo Int @map("week_no")

  units           Decimal @db.Decimal(18, 6)
  dividendPerUnit Decimal @map("dividend_per_unit") @db.Decimal(18, 6)
  amount          Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([termId, productId, studentProfileId, weekNo])
  @@map("dividend_payouts")
}

model BondPosition {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  holdingId String  @map("holding_id") @db.Uuid
  holding   Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  faceValue           Decimal @map("face_value") @db.Decimal(18, 6)
  couponRate          Decimal @map("coupon_rate") @db.Decimal(10, 6)
  couponIntervalWeeks Int     @map("coupon_interval_weeks")
  startWeekNo         Int     @map("start_week_no")
  maturityWeekNo      Int     @map("maturity_week_no")

  status BondPositionStatus @default(ACTIVE)

  couponPayouts BondCouponPayout[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([termId])
  @@index([holdingId])
  @@map("bond_positions")
}

model BondCouponPayout {
  id String @id @default(uuid()) @db.Uuid

  bondPositionId String       @map("bond_position_id") @db.Uuid
  bondPosition   BondPosition @relation(fields: [bondPositionId], references: [id], onDelete: Cascade)

  weekNo Int     @map("week_no")
  amount Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([bondPositionId, weekNo])
  @@map("bond_coupon_payouts")
}

model EconomicEvent {
  id String @id @default(uuid()) @db.Uuid

  title       String
  description String?

  eventType     EconomicEventType @map("event_type")
  defaultImpact Json              @map("default_impact")
  isRepeatable  Boolean           @default(false) @map("is_repeatable")

  termEvents            TermEvent[]
  productPrices         ProductPrice[]
  productLivePriceTicks ProductLivePriceTick[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("economic_events")
}

model TermEvent {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  eventId String        @db.Uuid
  event   EconomicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  startWeek Int @map("start_week")
  endWeek   Int @map("end_week")

  customImpact Json?           @map("custom_impact")
  status       TermEventStatus @default(SCHEDULED)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([termId, startWeek, endWeek])
  @@index([eventId])
  @@map("term_events")
}

model MarketRegime {
  id String @id @default(uuid()) @db.Uuid

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  name            MarketRegimeName
  muAdjustment    Decimal          @map("mu_adjustment") @db.Decimal(10, 6)
  sigmaAdjustment Decimal          @map("sigma_adjustment") @db.Decimal(10, 6)

  startWeek Int @map("start_week")
  endWeek   Int @map("end_week")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([termId, startWeek, endWeek])
  @@map("market_regimes")
}
